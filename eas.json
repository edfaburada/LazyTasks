{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_DOCTOR_SKIP": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_DOCTOR_SKIP": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}